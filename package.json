{
  "name": "ubuntu-portfolio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "wallpapers:generate": "node scripts/generate-wallpaper-catalog.mjs",
    "blog:generate": "node scripts/generate-blog-catalog.mjs",
    "content:generate": "npm run wallpapers:generate && npm run blog:generate",
    "predev": "npm run content:generate",
    "dev": "ng serve",
    "prestart": "npm run content:generate",
    "start": "ng serve",
    "prebuild": "npm run content:generate",
    "build": "ng build",
    "prewatch": "npm run content:generate",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.4.2",
  "dependencies": {
    "@angular/cdk": "^21.1.2",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "aplayer": "^1.10.1",
    "autoprefixer": "^10.4.24",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "marked": "^18.0.6",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.10",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "gray-matter": "^4.0.3",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
